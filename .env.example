# .env.example — copy to .env and fill in. NEVER commit .env.

# --- MinIO (object store for DVC + MLflow artifacts) ---
MINIO_ENDPOINT_INTERNAL=http://minio.minio.svc.cluster.local:9000
MINIO_ENDPOINT_LOCAL=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET_DVC=dvc
MINIO_BUCKET_MLFLOW=mlflow-artifacts

# --- DVC reads MinIO via AWS-style vars ---
AWS_ACCESS_KEY_ID=${MINIO_ROOT_USER}
AWS_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
AWS_DEFAULT_REGION=us-east-1

# --- MLflow ---
MLFLOW_TRACKING_URI_INTERNAL=http://mlflow.mlflow.svc.cluster.local:5000
MLFLOW_TRACKING_URI_LOCAL=http://localhost:5000
MLFLOW_S3_ENDPOINT_URL=${MINIO_ENDPOINT_INTERNAL}

# --- Kubeflow Pipelines ---
KFP_ENDPOINT=http://localhost:8080
KFP_NAMESPACE=kubeflow

# --- Grafana ---
GRAFANA_URL=http://localhost:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- Project (Wolf Point, MT) ---
SITE_LAT=48.30783
SITE_LON=-105.1017
SITE_TZ=UTC
PANEL_TILT_DEG=46.59
PANEL_AZIMUTH_DEG=180